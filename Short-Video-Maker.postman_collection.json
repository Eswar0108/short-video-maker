              "raw": "{\n  \"scenes\": [\n    {\n      \"text\": \"Everyone thinks successful people wake up at 5 AM. The truth is different.\",\n      \"searchTerms\": [\"myth\", \"success\", \"morning\"]\n    },\n    {\n      \"text\": \"Success is about consistency, not timing. Wake up when it works for YOUR schedule.\",\n      \"searchTerms\": [\"truth\", \"consistency\", \"time management\"]\n    },\n    {\n      \"text\": \"What time do YOU wake up? Comment below!\",\n      \"searchTerms\": [\"engagement\", \"community\", \"question\"]\n    }\n  ],\n  \"config\": {\n    \"orientation\": \"portrait\",\n    \"music\": \"contemplative\",\n    \"musicVolume\": \"high\",\n    \"captionPosition\": \"bottom\",\n    \"voice\": \"am_michael\",\n    \"paddingBack\": 2000\n  }\n}"
            },
