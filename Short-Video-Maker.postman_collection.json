              "raw": "{\n  \"scenes\": [\n    {\n      \"text\": \"Learn the Feynman Technique for faster learning. It's easier than you think.\",\n      \"searchTerms\": [\"learning\", \"technique\", \"education\"]\n    },\n    {\n      \"text\": \"Step 1: Choose a topic. Step 2: Explain it simply. Step 3: Find gaps. Step 4: Review and simplify.\",\n      \"searchTerms\": [\"steps\", \"process\", \"learning method\"]\n    },\n    {\n      \"text\": \"Master this technique and dominate your exams. Try it this week!\",\n      \"searchTerms\": [\"success\", \"mastery\", \"education\"]\n    }\n  ],\n  \"config\": {\n    \"orientation\": \"portrait\",\n    \"music\": \"chill\",\n    \"musicVolume\": \"high\",\n    \"captionPosition\": \"bottom\",\n    \"voice\": \"af_nova\",\n    \"paddingBack\": 2000\n  }\n}"
            },
